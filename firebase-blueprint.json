{
  "entities": {
    "user": {
      "title": "User",
      "description": "A seeker of divine guidance.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The display name of the user." },
        "email": { "type": "string", "format": "email", "description": "The email of the user." },
        "photoURL": { "type": "string", "format": "uri", "description": "The photo URL of the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user joined." }
      },
      "required": ["uid", "email"]
    },
    "chat": {
      "title": "Chat",
      "description": "A conversation with Lord Krishna.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who owns this chat." },
        "message": { "type": "string", "description": "The user's message." },
        "response": { "type": "string", "description": "Krishna's guidance." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["uid", "message", "response", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles."
    },
    "/chats/{chatId}": {
      "schema": "chat",
      "description": "Chat history for each user."
    }
  }
}
