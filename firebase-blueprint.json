{
  "entities": {
    "user": {
      "title": "User",
      "description": "A seeker of divine guidance.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The display name of the user." },
        "email": { "type": "string", "format": "email", "description": "The email of the user." },
        "photoURL": { "type": "string", "format": "uri", "description": "The photo URL of the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user joined." }
      },
      "required": ["uid", "email"]
    },
    "guidance": {
      "title": "Guidance",
      "description": "A record of divine guidance sought by a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who sought guidance." },
        "userName": { "type": "string", "description": "The name of the user." },
        "userEmail": { "type": "string", "format": "email", "description": "The email of the user." },
        "problem": { "type": "string", "description": "The problem described by the user." },
        "language": { "type": "string", "description": "The language of the guidance." },
        "response": { "type": "string", "description": "Krishna's guidance." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the guidance was sought." }
      },
      "required": ["uid", "problem", "response", "createdAt"]
    },
    "audioSetting": {
      "title": "Audio Setting",
      "description": "Configuration for the background melody.",
      "type": "object",
      "properties": {
        "url": { "type": "string", "format": "uri", "description": "The URL of the audio file." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the melody was last updated." },
        "fileName": { "type": "string", "description": "The name of the uploaded file." }
      },
      "required": ["url", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles."
    },
    "/guidance/{guidanceId}": {
      "schema": "guidance",
      "description": "Guidance history for each user."
    },
    "/settings/audio": {
      "schema": "audioSetting",
      "description": "Global background music configuration."
    }
  }
}
